import os, json, random, re
import numpy as np
from datetime import datetime

from socializ_server.memory.db import init_db
from socializ_server.memory.working import add_turn, get_history
from socializ_server.memory.episodic import save_episode, get_recent_episodes
from socializ_server.memory.soul_map import init_soul_map
from socializ_server.emotion.state import EmotionalState
from socializ_server.emotion.appraisal import appraise

BASE_PATH = "socializ_server/data/users"

########################################
# MEMORY FILES
########################################
def user_path(user_id):
    p = f"{BASE_PATH}/{user_id}"
    os.makedirs(p, exist_ok=True)
    return p

def mem_file(user_id):
    return f"{user_path(user_id)}/mem.json"

def vec_file(user_id):
    return f"{user_path(user_id)}/vec.json"

########################################
# JSON
########################################
def load_json(p, d):
    if not os.path.exists(p):
        return d
    try:
        return json.load(open(p, encoding="utf-8"))
    except:
        return d

def save_json(p, d):
    json.dump(d, open(p,"w",encoding="utf-8"), indent=2, ensure_ascii=False)

########################################
# MEMORY CORE
########################################
def load_mem(user_id):
    return load_json(mem_file(user_id), {
        "bond":0.3,
        "chaos":0.4,
        "last_topics":[]
    })

def save_mem(user_id, m):
    save_json(mem_file(user_id), m)

########################################
# EMBEDDING
########################################
def embed(text):
    import requests
    key = os.environ.get("OPENROUTER_API_KEY")

    r = requests.post(
        "https://openrouter.ai/api/v1/embeddings",
        headers={"Authorization":f"Bearer {key}"},
        json={"model":"text-embedding-3-small","input":text},
        timeout=30
    )

    data = r.json()
    return np.array(data["data"][0]["embedding"], dtype=np.float32)

########################################
# SEMANTIC MEMORY
########################################
def add_semantic(user_id, text):
    data = load_json(vec_file(user_id), [])

    chunks = [text[i:i+200] for i in range(0,len(text),200)]

    for c in chunks:
