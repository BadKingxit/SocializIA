    save_json(vec_file(user_id), data)

def search_semantic(user_id, query, k=5):
    data = load_json(vec_file(user_id), [])
    if not data:
        return []

    q = embed(query)

    scored = []
    for d in data:
        emb = np.array(d["emb"])
        sim = np.dot(q, emb)/(np.linalg.norm(q)*np.linalg.norm(emb))
        scored.append((sim, d["text"]))

    scored.sort(reverse=True)
    return [x[1] for x in scored[:k]]

########################################
# INTENT ENGINE
########################################
def decide_intent(mem, state):
    if state.label in ["raiva","irritada"]:
        return "provocar"
    if mem["bond"] > 0.6:
        return "aproximar"
    if mem["chaos"] > 0.6:
        return "zoar"
    return "responder"

########################################
# SHIMEJI SPEECH
########################################
def build_shimeji(reply):
    short = reply.split(".")[0][:40]

    emojis = ["😐","😏","🔥","😝","🥱","🤨"]
    return short, random.choice(emojis)

########################################
# CONTEXT (ATTENTION CHUNKS)
########################################
def build_context(history, episodes, semantic):
    ctx = []

    for h in history[-5:]:
        ctx.append(f"{h['role']}: {h['content']}")

    for e in episodes[:3]:
        ctx.append(f"[episodio]: {e['summary']}")

    for s in semantic[:3]:
        ctx.append(f"[memoria]: {s}")

    return "\n".join(ctx)

########################################
# LLM
########################################
def llm(messages, temp):
    import requests
    key = os.environ.get("OPENROUTER_API_KEY")

    r = requests.post(
        "https://openrouter.ai/api/v1/chat/completions",
        headers={"Authorization":f"Bearer {key}"},
        json={
            "model":"deepseek/deepseek-chat-v3-0324",
            "messages":messages,
            "temperature":temp
        },
        timeout=60
    )

    return r.json()["choices"][0]["message"]["content"]

########################################
# MAIN
########################################
def handle_chat(user_id, session_id, message):

    init_db()
    init_soul_map(user_id)

    mem = load_mem(user_id)

    state = EmotionalState()
    dv, da, _ = appraise(message, state)
    state.update(dv, da)

    add_turn(session_id, user_id, "user", message)
    history = get_history(session_id)

    episodes = get_recent_episodes(user_id, 5)
    semantic = search_semantic(user_id, message)

    context = build_context(history, episodes, semantic)
    intent = decide_intent(mem, state)

    system = f"""
Você é Amora.

Humana, natural.

INTENÇÃO: {intent}

REGRAS:
- responda direto
- não invente coisas aleatórias
- não repita assunto sem motivo

CONTEXTO:
{context}
"""

    messages = [
        {"role":"system","content":system},
        {"role":"user","content":message}
    ]

    temp = 0.8 + (mem["chaos"]*0.3)

    reply = llm(messages, temp)

    add_turn(session_id, user_id, "assistant", reply)

    short, react = build_shimeji(reply)

    try:
        add_semantic(user_id, message + " " + reply)
    except:
        pass

    save_episode(
        user_id=user_id,
        session_id=session_id,
        summary=reply[:50],
        emotion_label=state.label,
        valence=state.valence,
        arousal=state.arousal,
        importance=0.6
    )

    save_mem(user_id, mem)

    return {
        "reply": reply,
        "react": react,
        "shimeji": short,
        "emotional_state": state.to_dict(),
        "actions": []
    }
